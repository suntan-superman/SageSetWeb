{
  "name": "sageset-web",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "start": "vite --port 3000 --open",
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "pixel:test": "node scripts/verify-meta-pixel.mjs",
    "pixel:test:live": "node scripts/verify-meta-pixel.mjs --live",
    "pixel:test:live:headful": "node scripts/verify-meta-pixel.mjs --live --headful",
    "pixel:install-browser": "puppeteer browsers install chrome",
    "verify:release": "node ./scripts/verify-release.js",
    "verify:release:local": "node ./scripts/verify-release.js --target local",
    "verify:release:prod": "node ./scripts/verify-release.js --target production",
    "test:puppeteer": "node ./scripts/verify-release.js --only routes",
    "test:meta": "node ./scripts/verify-release.js --only meta"
  },
  "dependencies": {
    "@heroicons/react": "^2.2.0",
    "@syncfusion/ej2-base": "^31.2.2",
    "@syncfusion/ej2-buttons": "^31.2.2",
    "@syncfusion/ej2-calendars": "^31.2.2",
    "@syncfusion/ej2-dropdowns": "^31.2.2",
    "@syncfusion/ej2-inputs": "^31.2.2",
    "@syncfusion/ej2-navigations": "^31.2.2",
    "@syncfusion/ej2-popups": "^31.2.2",
    "@syncfusion/ej2-react-schedule": "^31.2.2",
    "firebase": "^12.7.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^6.30.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.5.1",
    "puppeteer": "^25.2.1",
    "tailwindcss": "^3.4.17",
    "vite": "^6.0.7"
  }
}
